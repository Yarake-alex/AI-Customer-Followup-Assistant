# 上传文件大小限制，单位 MB，默认 10
MAX_UPLOAD_SIZE_MB=10

# 管理接口密钥。设置后，请求需携带 Header: X-Admin-Key
# 本地开发可留空，生产环境必须设置强随机值
ADMIN_API_KEY=

# LLM 提供方：
# mock: 不调用真实模型，适合本地开发
# openai_compatible: 使用 OpenAI 兼容接口，例如 DeepSeek / 通义 / 智谱
LLM_PROVIDER=mock

# OpenAI-compatible API Key（LLM_PROVIDER=openai_compatible 时必填）
OPENAI_API_KEY=

# OpenAI-compatible Base URL，示例：https://api.deepseek.com
OPENAI_BASE_URL=

# 模型名称，示例：deepseek-chat
OPENAI_MODEL=deepseek-chat

# 允许跨域访问的前端地址，多个地址用英文逗号分隔
# 本地开发示例：
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8000

# 生产环境示例：
# CORS_ORIGINS=https://your-frontend.example.com
