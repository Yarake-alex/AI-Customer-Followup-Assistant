# 运行环境：development / production / test
# test 模式下不读取 .env，仅使用环境变量或默认值
APP_ENV=development

# Cookie Secure 标志。
# HTTP IP 访问时设为 false；HTTPS 域名部署时必须设为 true
COOKIE_SECURE=false

# 上传文件大小限制，单位 MB，默认 10
MAX_UPLOAD_SIZE_MB=10

# 访问密码。设置后，用户需登录后才能使用系统。
# 首次启动会用 APP_ADMIN_USERNAME + APP_ACCESS_PASSWORD 创建管理员账号。
# 本地开发可留空（免登录）；公网部署必须设置强密码。
APP_ADMIN_USERNAME=admin
APP_ACCESS_PASSWORD=

# 是否允许公开注册。生产环境建议保持 false，由管理员通过 /auth/users 创建账号。
ENABLE_PUBLIC_REGISTRATION=false

# 签名 Cookie 的密钥。APP_ACCESS_PASSWORD 设置时必填，长度不少于 32 字符。
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# 正式访问地址。建议绑定域名并启用 HTTPS，例如：https://ai.example.com
PUBLIC_SITE_URL=

# LLM 提供方：
# mock: 不调用真实模型，适合本地开发
# openai_compatible: 使用 OpenAI 兼容接口，例如 DeepSeek / 通义 / 智谱
LLM_PROVIDER=mock

# OpenAI-compatible API Key（LLM_PROVIDER=openai_compatible 时必填）
OPENAI_API_KEY=

# OpenAI-compatible Base URL，示例：https://api.deepseek.com
OPENAI_BASE_URL=

# 模型名称，示例：deepseek-chat
OPENAI_MODEL=deepseek-chat

# 允许跨域访问的前端地址，多个地址用英文逗号分隔
# 本地开发示例：
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:8000

# 生产环境示例：
# CORS_ORIGINS=https://your-frontend.example.com

# 数据库连接地址。
# 本地 SQLite 示例：sqlite:///./customer_assistant.db
# Docker SQLite 示例：sqlite:///./data/customer_assistant.db
# PostgreSQL 示例：postgresql+psycopg://ai_customer:strong-password@postgres:5432/ai_customer
DATABASE_URL=sqlite:///./customer_assistant.db

# PostgreSQL 密码（使用 docker-compose.postgres.yml 时生效）
# 生产环境必须修改为强密码，并在 .env 中设置
POSTGRES_PASSWORD=change-this-postgres-password

# ─── Vector Search (Embedding + 向量数据库) ───
# ═══════════════════════════════════════════════════════════════
# 启用步骤：
#   1. 填写下方 OPENAI_API_KEY / OPENAI_BASE_URL（LLM 大模型）
#   2. 填写 EMBEDDING_API_KEY 或复用 OPENAI_API_KEY
#   3. 将 VECTOR_SEARCH_ENABLED 改为 true
#   4. （可选）安装 chromadb：pip install -r requirements-vector.txt
# ═══════════════════════════════════════════════════════════════

# 主开关：true 使用向量检索，false 降级到传统 TF-IDF 检索
# 请先填好 API Key 再开启！
VECTOR_SEARCH_ENABLED=false

# 嵌入提供方：openai_compatible（API 接口）/ local（本地模型）/ test（测试用）
# openai_compatible 使用 LLM 同一套 API Key 即可，无需额外安装依赖（Docker 推荐）
# local 需要安装：pip install -r requirements-embedding-local.txt（约 2.5GB）
EMBEDDING_PROVIDER=openai_compatible

# 嵌入维度：0=自动检测模型输出维度；设为具体值可覆盖（必须与模型匹配）
EMBEDDING_DIMENSION=0

# 本地嵌入模型（EMBEDDING_PROVIDER=local 时生效）
# 推荐：BAAI/bge-m3（多语言 1024 维）、BAAI/bge-large-zh-v1.5（中文 1024 维）
# 轻量：BAAI/bge-small-zh-v1.5（中文 512 维）
EMBEDDING_MODEL=BAAI/bge-m3

# API 嵌入模型 Key（留空则沿用 OPENAI_API_KEY）
EMBEDDING_API_KEY=

# API 嵌入模型地址（留空则沿用 OPENAI_BASE_URL）
# Qwen 示例：https://dashscope.aliyuncs.com/compatible-mode/v1
# Zhipu 示例：https://open.bigmodel.cn/api/paas/v4
EMBEDDING_BASE_URL=

# API 嵌入模型名称（EMBEDDING_PROVIDER=openai_compatible 时生效）
# Qwen：text-embedding-v3；Zhipu：embedding-3
EMBEDDING_MODEL_NAME=text-embedding-v3

# ChromaDB 持久化目录（SQLite 开发环境）
CHROMA_PERSIST_DIR=./data/chroma_db

# 向量检索返回 Top-K 数量
VECTOR_SEARCH_TOP_K=4
